# ─────────────────────────────────────────────────────────────
# Voice Agent Builder — environment template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ─────────────────────────────────────────────────────────────

# Public base URL of this app (used for Vapi webhook server.url).
# Local dev: your ngrok/tunnel URL. Prod: the Vercel URL.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Anthropic (builder graph router/editor/clarifier + eval judge) ──
# Set a HARD SPEND CAP in the Anthropic console (all-Claude stack).
ANTHROPIC_API_KEY=

# Model ids (defaults live in code; override here if needed)
BUILDER_MODEL=claude-sonnet-5
# In-call id goes to Vapi's anthropic provider — dated snapshot required.
INCALL_MODEL=claude-haiku-4-5-20251001

# ── LangSmith (trace the builder graph's phases: router/clarifier/editor/compiler/responder) ──
# Optional — leave LANGSMITH_TRACING unset/false to disable tracing entirely (no-op wrapper).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=voice-agent-builder

# ── Vapi (voice infra) — set a HARD SPEND CAP in Vapi ──
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# Vapi Dashboard → API Keys → Public Key. Client-side (browser calls), safe to expose.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# ── Supabase (Postgres) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cal.com (booking) — mock fallback used until set ──
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# ── Demo ──
# Every seeded lead's phone routes here. Your own real number, E.164 (+15551234567).
DEMO_PHONE=
# Every Cal.com booking's attendee email routes here (seed leads use fake
# .example addresses Cal.com rejects as undeliverable). Your own real email.
DEMO_EMAIL=
